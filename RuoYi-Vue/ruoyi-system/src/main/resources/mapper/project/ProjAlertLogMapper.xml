<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.project.ProjAlertLogMapper">
  <resultMap id="ProjAlertLogResult" type="com.ruoyi.system.domain.project.ProjAlertLog">
    <id property="logId" column="log_id"/>
    <result property="alertId" column="alert_id"/>
    <result property="actionType" column="action_type"/>
    <result property="actionBy" column="action_by"/>
    <result property="actionTime" column="action_time"/>
    <result property="actionRemark" column="action_remark"/>
  </resultMap>

  <select id="selectAlertLogList" resultMap="ProjAlertLogResult">
    select log_id, alert_id, action_type, action_by, action_time, action_remark
    from proj_alert_log
    where alert_id = #{alertId}
    order by action_time asc, log_id asc
  </select>

  <insert id="insertAlertLog" parameterType="com.ruoyi.system.domain.project.ProjAlertLog" useGeneratedKeys="true" keyProperty="logId">
    insert into proj_alert_log(alert_id, action_type, action_by, action_time, action_remark)
    values(#{alertId}, #{actionType}, #{actionBy}, #{actionTime}, #{actionRemark})
  </insert>
</mapper>
